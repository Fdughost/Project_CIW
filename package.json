{
  "name": "chloe-in-wonderland",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit": "npm audit --audit-level=moderate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
